{
  "manifest_version": 3,
  "name": "SEO Inspector",
  "version": "1.8",
  "description": "Quick SEO metadata inspector — title, meta description, headings, canonical, and alt text overlay.",
  "browser_specific_settings": {
    "gecko": {
      "id": "seo-inspector@brianvoit",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["websiteActivity"],
        "optional": []
      }
    }
  },
  "permissions": ["storage", "activeTab", "scripting", "tabs", "menus"],
  "host_permissions": ["https://api.github.com/*", "https://api.anthropic.com/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
